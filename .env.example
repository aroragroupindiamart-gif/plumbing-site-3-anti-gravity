# ─── Brand ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BRAND_NAME=Your Brand Name
NEXT_PUBLIC_PHONE_NUMBER=(800) 555-0100
NEXT_PUBLIC_PHONE_TEL=8005550100
NEXT_PUBLIC_SITE_URL=https://www.yoursite.com

# ─── Niche ────────────────────────────────────────────────────────────────────
# The industry/service category for this directory
NEXT_PUBLIC_NICHE=Home Services
NEXT_PUBLIC_NICHE_PLURAL=Service Providers
NEXT_PUBLIC_NICHE_SINGULAR=Service Provider
# Schema.org LocalBusiness subtype — https://schema.org/LocalBusiness
NEXT_PUBLIC_SCHEMA_TYPE=LocalBusiness

# ─── Analytics & Ads ──────────────────────────────────────────────────────────
# Google Analytics — get from analytics.google.com (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
# Google AdSense — get from adsense.google.com (format: ca-pub-XXXXXXXXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_ID=
# Google Search Console verification token (the content="" value only)
NEXT_PUBLIC_GSC_TOKEN=

# ─── Admin panel protection (optional) ────────────────────────────────────────
ADMIN_USER=admin
ADMIN_PASS=changeme
